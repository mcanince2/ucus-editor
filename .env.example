# ─────────────────────────────────────────────────────────────
# Uçuş Saati Studio — environment configuration
# Copy to ".env.local" and adjust if needed. All values are OPTIONAL:
# the app auto-detects local tooling and works without any keys.
# ─────────────────────────────────────────────────────────────

# Absolute paths to ffmpeg / ffprobe. Leave unset to use the ones on PATH.
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe

# Speech-to-text provider for Turkish subtitles.
# "auto"   -> use local `whisper` CLI if present, else OpenAI if a key is set (default)
# "local"  -> force local openai-whisper CLI
# "openai" -> force OpenAI Whisper API (requires OPENAI_API_KEY)
TRANSCRIBE_PROVIDER=auto

# Local whisper model: tiny | base | small | medium | large
# "small" is a good speed/quality balance for Turkish. Model downloads on first use.
WHISPER_MODEL=small

# Path to the local whisper executable (openai-whisper). Leave unset to use PATH.
# WHISPER_PATH=/Library/Frameworks/Python.framework/Versions/3.13/bin/whisper

# Optional: OpenAI key, used only when provider is "openai" or "auto" with no local whisper.
# OPENAI_API_KEY=sk-...
